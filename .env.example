# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Database (local Homebrew Postgres — create once if not using Docker)
# psql -d postgres -c "CREATE USER rideuser WITH PASSWORD 'ridepass';"
# psql -d postgres -c "CREATE DATABASE ridebooking OWNER rideuser;"
# cd Backend && alembic upgrade head
DATABASE_URL=postgresql+asyncpg://rideuser:ridepass@localhost:5432/ridebooking

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated; production only — development allows any localhost port)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:8000

# Twilio Verify — required for real SMS OTP on your phone
# 1. Sign up at https://www.twilio.com/
# 2. Create a Verify Service: https://console.twilio.com/us1/develop/verify/services
# 3. Paste credentials below into Backend/.env and restart uvicorn
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Without Twilio (local development):
# - OTP is NOT sent via SMS
# - The code is shown in the Driver Panel app (yellow banner) and backend terminal logs
# - Never enable DEBUG in production without Twilio configured

# Google Maps — used for place search, directions, reverse geocode, and place details
GOOGLE_MAPS_API_KEY=

# Razorpay — subscription checkout + ride QR payments (use test keys in development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Render.com deployment ---
# Render auto-sets DATABASE_URL from the linked Postgres database.
# Set these manually in the Render dashboard after deploy:
#   REDIS_URL=rediss://...          (free tier: https://upstash.com)
#   CORS_ORIGINS=https://your-frontend.onrender.com
#   APP_ENV=production
#   DEBUG=false
# SECRET_KEY and JWT_SECRET_KEY are auto-generated by render.yaml
