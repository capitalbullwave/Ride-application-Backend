# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Database (local Homebrew Postgres — create once if not using Docker)
# psql -d postgres -c "CREATE USER rideuser WITH PASSWORD 'ridepass';"
# psql -d postgres -c "CREATE DATABASE ridebooking OWNER rideuser;"
# cd Backend && alembic upgrade head
DATABASE_URL=postgresql+asyncpg://rideuser:ridepass@localhost:5432/ridebooking

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated; production only — development allows any localhost port)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:8000

# Twilio Verify — SMS OTP for user + driver auth
# 1. Sign up at https://www.twilio.com/
# 2. Create a Verify Service: https://console.twilio.com/us1/develop/verify/services
# 3. Paste credentials below into Backend/.env and restart uvicorn
#
# TWILIO_ENABLED=false → no SMS; verify with OTP 123456
# TWILIO_ENABLED=true  → real SMS via Twilio (credentials required)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# Required for SOS / women-safety SMS to emergency contacts (Messaging API).
# Verify Service alone cannot send free-form SOS texts — buy/assign a Twilio number:
# https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_PHONE_NUMBER=

# Google Maps — used for place search, directions, reverse geocode, and place details
GOOGLE_MAPS_API_KEY=

# Cashfree — ride UPI QR, wallet top-up, subscriptions
# Dashboard → Developers → API Keys. Use sandbox keys for testing.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox

# OpenAI (User Panel AI assistant)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
